---
import { Image } from 'astro:assets';
import logo from '../images/logo.png';
import { business } from '../data/site';

const nav = [
  { label: 'Home', href: '/' },
  { label: 'Services', href: '/services' },
  { label: 'Gallery', href: '/gallery' },
  { label: 'About', href: '/#about' },
];
---

<header
  class="sticky top-0 z-50 border-b border-charcoal-700/60 bg-charcoal-850/95 backdrop-blur"
>
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3">
    <a href="/" class="flex shrink-0 items-center" aria-label={`${business.name} — home`}>
      <Image
        src={logo}
        alt={business.name}
        class="h-12 w-auto md:h-14"
        widths={[200, 320]}
        loading="eager"
      />
    </a>

    <nav class="hidden items-center gap-6 md:flex" aria-label="Main">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class="text-sm font-medium tracking-wide text-ash-300 transition-colors hover:text-volt-400"
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-2 sm:gap-3">
      <a
        href={business.phoneHref}
        class="hidden items-center gap-2 rounded border border-volt-500/60 px-3 py-2 text-sm font-semibold text-volt-300 transition-colors hover:bg-volt-500/10 sm:flex"
      >
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path
            d="M6.6 10.8a15.1 15.1 0 0 0 6.6 6.6l2.2-2.2a1 1 0 0 1 1-.25 11.4 11.4 0 0 0 3.6.58 1 1 0 0 1 1 1V20a1 1 0 0 1-1 1A17 17 0 0 1 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1 11.4 11.4 0 0 0 .57 3.6 1 1 0 0 1-.25 1z"
          ></path>
        </svg>
        {business.phone}
      </a>
      <a
        href="/#contact"
        class="rounded bg-volt-500 px-3 py-2 text-sm font-semibold text-charcoal-950 transition-colors hover:bg-volt-400"
      >
        Get a Quote
      </a>
      <button
        id="menu-btn"
        class="p-2 text-ash-300 md:hidden"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" d="M4 7h16M4 12h16M4 17h16"></path>
        </svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="hidden border-t border-charcoal-700/60 md:hidden">
    <nav class="flex flex-col px-4 py-2" aria-label="Mobile">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class="border-b border-charcoal-800 py-3 text-ash-100 last:border-0 hover:text-volt-400"
          >
            {item.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>

<!-- Mobile sticky call bar -->
<a
  href={business.phoneHref}
  class="fixed inset-x-0 bottom-0 z-50 flex items-center justify-center gap-2 bg-volt-500 py-3 font-semibold text-charcoal-950 shadow-[0_-4px_16px_rgba(0,0,0,0.4)] sm:hidden"
>
  <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
    <path
      d="M6.6 10.8a15.1 15.1 0 0 0 6.6 6.6l2.2-2.2a1 1 0 0 1 1-.25 11.4 11.4 0 0 0 3.6.58 1 1 0 0 1 1 1V20a1 1 0 0 1-1 1A17 17 0 0 1 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1 11.4 11.4 0 0 0 .57 3.6 1 1 0 0 1-.25 1z"
    ></path>
  </svg>
  Call {business.phone} — 24/7
</a>

<script>
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    btn.setAttribute('aria-expanded', String(open));
  });
  menu?.querySelectorAll('a').forEach((a) =>
    a.addEventListener('click', () => {
      menu.classList.add('hidden');
      btn?.setAttribute('aria-expanded', 'false');
    })
  );
</script>
