---
// Decorative PCB-style circuit divider with a traveling current pulse.
// Purely visual; self-contained (styles are scoped to this component).
---

<div class="circuit-divider mx-auto max-w-6xl px-4" aria-hidden="true">
  <svg viewBox="0 0 1200 64" fill="none" class="h-12 w-full" preserveAspectRatio="xMidYMid meet">
    <defs>
      <linearGradient id="cd-fade" x1="0" y1="0" x2="1200" y2="0" gradientUnits="userSpaceOnUse">
        <stop offset="0" stop-color="currentColor" stop-opacity="0" />
        <stop offset="0.08" stop-color="currentColor" stop-opacity="1" />
        <stop offset="0.92" stop-color="currentColor" stop-opacity="1" />
        <stop offset="1" stop-color="currentColor" stop-opacity="0" />
      </linearGradient>
    </defs>

    <!-- secondary traces (dimmer, offset) -->
    <g stroke="url(#cd-fade)" stroke-width="1" opacity="0.28">
      <path d="M0 14 H300 l12 12 H520" />
      <path d="M680 26 l12 -12 H1010 l10 10 H1200" />
      <path d="M0 50 H180 l10 -10 H420 l12 12 H560" />
      <path d="M640 52 H900 l12 -12 H1200" />
    </g>

    <!-- main trace: PCB-style 45° bends routed around the chip -->
    <path
      class="cd-main"
      d="M0 32 H420 l14 -14 h60 l14 14 H540 M660 32 h26 l14 14 h80 l-14 -14 h180 l12 -12 H1200"
      stroke="url(#cd-fade)"
      stroke-width="1.5"
    />
    <!-- traveling pulse rides the same geometry -->
    <path
      class="cd-pulse"
      d="M0 32 H420 l14 -14 h60 l14 14 H540 M660 32 h26 l14 14 h80 l-14 -14 h180 l12 -12 H1200"
      stroke-width="2.5"
      stroke-linecap="round"
    />

    <!-- IC chip in the center gap -->
    <g class="cd-chip">
      <rect x="556" y="20" width="88" height="24" rx="3" fill="none" stroke="currentColor" stroke-width="1.5" />
      <rect x="588" y="28" width="24" height="8" rx="1" fill="currentColor" opacity="0.5" />
      <!-- pins -->
      <g stroke="currentColor" stroke-width="1.5">
        <path d="M568 20 v-6 M584 20 v-6 M616 20 v-6 M632 20 v-6" />
        <path d="M568 44 v6 M584 44 v6 M616 44 v6 M632 44 v6" />
      </g>
      <!-- chip connects to main trace -->
      <path d="M540 32 h16 M644 32 h16" stroke="currentColor" stroke-width="1.5" />
    </g>

    <!-- vias: hollow solder pads at trace junctions -->
    <g class="cd-vias" stroke="currentColor" stroke-width="1.5" fill="none">
      <circle cx="420" cy="32" r="4" />
      <circle cx="780" cy="46" r="4" />
      <circle cx="946" cy="32" r="4" />
      <circle cx="300" cy="14" r="3" opacity="0.4" />
      <circle cx="900" cy="52" r="3" opacity="0.4" />
    </g>
    <g fill="currentColor">
      <circle class="cd-node" cx="420" cy="32" r="1.5" />
      <circle class="cd-node" cx="780" cy="46" r="1.5" />
      <circle class="cd-node" cx="946" cy="32" r="1.5" />
    </g>
  </svg>
</div>

<style>
  .circuit-divider {
    color: var(--color-volt-500);
  }
  .cd-main {
    opacity: 0.55;
  }
  .cd-chip,
  .cd-vias {
    opacity: 0.75;
  }

  /* Current pulse: a short bright dash travels the full trace */
  .cd-pulse {
    stroke: var(--color-volt-300);
    stroke-dasharray: 46 1400;
    stroke-dashoffset: 1446;
    filter: drop-shadow(0 0 6px var(--color-volt-400));
    animation: cd-travel 7s linear infinite;
  }
  @keyframes cd-travel {
    to {
      stroke-dashoffset: 0;
    }
  }

  /* Via nodes breathe softly, staggered */
  .cd-node {
    animation: cd-breathe 3.4s ease-in-out infinite;
  }
  .cd-node:nth-of-type(2) {
    animation-delay: 1.1s;
  }
  .cd-node:nth-of-type(3) {
    animation-delay: 2.2s;
  }
  @keyframes cd-breathe {
    0%,
    100% {
      opacity: 0.35;
    }
    50% {
      opacity: 1;
      filter: drop-shadow(0 0 4px currentColor);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .cd-pulse {
      animation: none;
      stroke-dasharray: none;
      stroke: transparent;
    }
    .cd-node {
      animation: none;
    }
  }
</style>
