---
// Decorative circuit-trace divider. Purely visual.
---

<div class="circuit-divider mx-auto max-w-6xl px-4" aria-hidden="true">
  <svg
    viewBox="0 0 1200 40"
    fill="none"
    stroke="currentColor"
    stroke-width="1.5"
    class="h-8 w-full"
    preserveAspectRatio="xMidYMid meet"
  >
    <path d="M0 20 H340 l14 -12 h120 l14 12 H700 l12 10 h130 l12 -10 H1200" />
    <circle class="pulse" cx="340" cy="20" r="4" fill="currentColor" stroke="none" />
    <circle class="pulse" cx="700" cy="20" r="4" fill="currentColor" stroke="none" />
    <circle class="pulse" cx="854" cy="30" r="4" fill="currentColor" stroke="none" />
    <rect x="470" y="4" width="8" height="8" fill="currentColor" stroke="none" opacity="0.7" />
  </svg>
</div>
